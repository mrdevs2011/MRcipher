rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default: deny everything.
    match /{document=**} {
      allow read, write: if false;
    }

    // Test chat demo: encrypted messages collection.
    // Anyone can read (two-phone demo without auth linking).
    // Only authenticated users can create; update/delete forbidden.
    match /messages/{messageId} {
      allow read: if true;
      allow create: if request.auth != null
                      && request.resource.data.keys().hasAll(['text', 'from', 'createdAt']);
      allow update: if false;
      allow delete: if false;
    }
  }
}
