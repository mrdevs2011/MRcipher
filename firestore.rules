rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny all client-side access.
    // Every read/write must go through Next.js API routes using Firebase Admin SDK.
    match /{document=**} {
      allow read, write: if false;
    }

    // Server-managed user documents.
    // The Admin SDK bypasses these rules, but if any client ever tries direct access,
    // it is denied here.
    match /users/{uid} {
      allow read: if false;
      allow write: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // API keys: raw keys are never stored; only hashes and metadata live here.
    // Direct client access is forbidden.
    match /api_keys/{keyId} {
      allow read: if false;
      allow write: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // Usage logs: write-only from server, never readable by clients.
    match /logs/{logId} {
      allow read: if false;
      allow write: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // Usage aggregates: write-only from server, never readable by clients.
    // The /api/v1/usage endpoint returns a derived view, not this raw doc.
    match /usage_aggregates/{uid} {
      allow read: if false;
      allow write: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // Optional: allow users to read their own public profile if you ever add one.
    // Currently disabled; enable only when needed.
    // match /profiles/{uid} {
    //   allow read: if request.auth != null && request.auth.uid == uid;
    //   allow write: if false;
    // }
  }
}
