rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny all client-side access.
    // Every sensitive read/write must go through Next.js API routes via Firebase Admin SDK.
    match /{document=**} {
      allow read, write: if false;
    }

    // Server-managed user documents.
    // The Admin SDK bypasses these rules; direct client access is denied.
    match /users/{uid} {
      allow read: if false;
      allow write: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // API keys: raw keys are stored 1:1 alongside metadata so the UI can
    // rebind automatically. Writes are still server-only (Admin SDK), but
    // the OWNER may read their own key docs directly — this is what powers
    // the real-time dashboard <-> CLI sync (a key created via `mrcipher
    // login`/`mrcipher keys create` appears on the website instantly via
    // onSnapshot, with no extra server round trip). This is no more
    // permissive than today's REST /api/v1/keys endpoint, which already
    // returns raw keys to their owner.
    match /api_keys/{keyId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.uid;
      allow write: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // Usage logs: write-only from server, never readable by clients.
    match /logs/{logId} {
      allow read: if false;
      allow write: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // User UI preferences (e.g. translator selected API key). Server-managed.
    match /user_preferences/{uid} {
      allow read: if false;
      allow write: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // Usage aggregates: write-only from server, never readable by clients.
    // The /api/v1/usage endpoint returns a derived view, not this raw doc.
    match /usage_aggregates/{uid} {
      allow read: if false;
      allow write: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // Test app messages: encrypted chat demo.
    // - Authenticated users can create messages.
    // - Anyone can read messages (required for real-time two-phone demo).
    // - Updates and deletes are forbidden; messages are append-only.
    match /messages/{messageId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if false;
      allow delete: if false;
    }
  }
}
