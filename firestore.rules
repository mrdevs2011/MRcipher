rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // All collections are server-managed via Firebase Admin SDK.
    // Client-side direct access is denied by default.
    match /users/{uid} {
      allow read: if false;
      allow write: if false;
    }

    match /api_keys/{key} {
      allow read: if false;
      allow write: if false;
    }

    match /logs/{log} {
      allow read: if false;
      allow write: if false;
    }
  }
}
